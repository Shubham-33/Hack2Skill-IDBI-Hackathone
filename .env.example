# Prospect Assist AI — environment template.
# Copy to .env and fill in. .env is git-ignored; never commit real keys.

# NVIDIA NIM free API key — get one free at https://build.nvidia.com
# Without it the app runs in DEGRADED mode (deterministic fallbacks, no AI copy) — nothing breaks.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default model (interactive paths use a fast small model).
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct
